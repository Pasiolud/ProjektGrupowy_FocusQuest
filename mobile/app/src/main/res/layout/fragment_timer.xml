<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/timer_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <TextView
            android:id="@+id/timer_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sesja Pracy"
            android:textColor="@color/primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:textAllCaps="true"
            android:layout_marginTop="8dp" />

        <Space android:layout_width="match_parent" android:layout_height="8dp" />

        <TextView
            android:id="@+id/timer_avatar_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="32sp"
            android:layout_marginBottom="4dp" />

        <Space android:layout_width="match_parent" android:layout_height="24dp" />

        <FrameLayout
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:layout_gravity="center_horizontal">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/timer_progress_track"
                android:layout_width="240dp"
                android:layout_height="240dp"
                android:layout_gravity="center"
                app:indicatorColor="@color/surface_container"
                app:trackColor="@color/surface_container"
                app:indicatorSize="240dp"
                app:trackThickness="10dp"
                app:trackCornerRadius="5dp"
                android:progress="100"
                android:indeterminate="false" />

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/timer_progress"
                android:layout_width="240dp"
                android:layout_height="240dp"
                android:layout_gravity="center"
                app:indicatorColor="@color/primary"
                app:trackColor="@color/surface_container"
                app:indicatorSize="240dp"
                app:trackThickness="10dp"
                app:trackCornerRadius="5dp"
                android:progress="100"
                android:indeterminate="false" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/timer_display"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="25:00"
                    android:textColor="@color/on_surface"
                    android:textSize="52sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.02"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/timer_status_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="gotowy"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08" />

            </LinearLayout>
        </FrameLayout>

        <Space android:layout_width="match_parent" android:layout_height="40dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/startButton"
            style="@style/Widget.FocusGuardian.Button"
            android:layout_width="200dp"
            android:layout_height="56dp"
            android:text="Start"
            android:textAllCaps="false"
            android:textSize="17sp"
            android:textStyle="bold"
            app:backgroundTint="@color/primary"
            app:cornerRadius="28dp" />

        <Space android:layout_width="match_parent" android:layout_height="24dp" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.FocusGuardian.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/gold_light"
            app:cardCornerRadius="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Nagroda za sesję"
                    android:textColor="@color/on_surface"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/timer_reward_preview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+25 monet  +1500 XP"
                    android:textColor="@color/gold"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <Space android:layout_width="match_parent" android:layout_height="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Przytrzymaj tytuł, by przełączyć tryb testowy"
            android:textColor="@color/on_surface_variant"
            android:textSize="11sp"
            android:alpha="0.6" />

        <Space android:layout_width="match_parent" android:layout_height="80dp" />

    </LinearLayout>
</ScrollView>
