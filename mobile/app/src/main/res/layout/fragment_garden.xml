<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">
    
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/garden_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Twój Ogród"
            android:textColor="@color/primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Twoje rośliny rosną, gdy Ty się uczysz"
            android:textColor="@color/on_surface_variant"
            android:textSize="14sp"
            android:layout_marginTop="4dp" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="32dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Zasadzone Drzewa"
            android:textColor="@color/on_surface"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- Grid of 3 garden slots -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Slot 1 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_slot_1"
                style="@style/Widget.FocusGuardian.Card"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginBottom="12dp">
                <LinearLayout
                    android:id="@+id/layout_slot_1"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp">
                    <TextView
                        android:id="@+id/text_slot_1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Puste miejsce\nKliknij nasiono by zasadzić"
                        android:textAlignment="center"
                        android:textColor="@color/on_surface_variant"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Slot 2 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_slot_2"
                style="@style/Widget.FocusGuardian.Card"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginBottom="12dp">
                <LinearLayout
                    android:id="@+id/layout_slot_2"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp">
                    <TextView
                        android:id="@+id/text_slot_2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Puste miejsce\nKliknij nasiono by zasadzić"
                        android:textAlignment="center"
                        android:textColor="@color/on_surface_variant"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Slot 3 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_slot_3"
                style="@style/Widget.FocusGuardian.Card"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginBottom="24dp">
                <LinearLayout
                    android:id="@+id/layout_slot_3"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp">
                    <TextView
                        android:id="@+id/text_slot_3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Puste miejsce\nKliknij nasiono by zasadzić"
                        android:textAlignment="center"
                        android:textColor="@color/on_surface_variant"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Skarbiec Nasion"
            android:textColor="@color/on_surface"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />
            
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:id="@+id/seeds_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="4dp">
                
                <TextView
                    android:id="@+id/no_seeds_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Brak nasion. Skupiaj się, by je zdobyć!" />
                    
            </LinearLayout>
        </HorizontalScrollView>

    </LinearLayout>
</ScrollView>
